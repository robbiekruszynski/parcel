# From Supabase Dashboard -> Project Settings -> API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Use ONE of these (copy the FULL key, not a truncated preview):
# - Legacy API Keys tab -> anon key (starts with eyJ...)
# - API Keys tab -> Publishable key (starts with sb_publishable_...)
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Google Cloud Console -> Maps SDK for Android (optional on iOS)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# From https://www.strava.com/settings/api
EXPO_PUBLIC_STRAVA_CLIENT_ID=

# Server-side only. Set in Supabase Edge Function secrets, NOT in the Expo bundle.
STRAVA_CLIENT_SECRET=
STRAVA_WEBHOOK_VERIFY_TOKEN=
